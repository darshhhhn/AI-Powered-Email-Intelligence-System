# Copy to `.env` and adjust. Never commit real secrets.

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Use HTTPS in production so the session cookie can be marked secure:
# DJANGO_SESSION_COOKIE_SECURE=True

IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Newest N messages to download from the server; UI shows MAIL_PAGE_SIZE per page.
# Use 50+ here if you want pagination across several pages.
MAIL_FETCH_LIMIT=10
MAIL_PAGE_SIZE=10
